model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  username String  @unique
  avatar   String?

  role      ROLE
  isBlocked Boolean @map("is_blocked")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inventories Inventory[]
  accesses    InventoryAccess[]
  items       Item[]
  comments    Comment[]

  @@map("users")
}

enum ROLE {
  USER
  ADMIN
}

model Inventory {
  id String @id @default(uuid())

  title       String
  description String
  category    String
  imageUrl    String  @map("image_url")

  isPublic Boolean @default(false) @map("is_public")

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accesses InventoryAccess[]

  fields         InventoryField[] @relation("InventoryFields")
  customIdFormat CustomIdFormat?
  items          Item[]
  comments       Comment[]
  inventoryTags  InventoryTag[]

  @@map("inventories")
}
